# ============================================================
# Market Incident Copilot — 환경변수
# 사용법: cp .env.example .env 후 값 채우기
# ============================================================

# ── Infrastructure ──────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=upbit-tickers

DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=upbit
DB_USER=postgres
DB_PASSWORD=postgres

# ── Consumer ────────────────────────────────────────────────
BATCH_SIZE=100
BATCH_TIMEOUT_SEC=1.0

# ── AI Agent (required for 분석 리포트) ─────────────────────
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# ── News API (optional, 뉴스 검색용) ───────────────────────
# CryptoPanic: https://cryptopanic.com/developers/api/ (무료)
CRYPTOPANIC_API_KEY=
# SerpAPI: https://serpapi.com/ (폴백, 월 100회 무료)
SERPAPI_API_KEY=

# ── Telegram 알림 (optional) ───────────────────────────────
# @BotFather에서 봇 생성 후 토큰 발급
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── KakaoTalk 알림 (optional) ──────────────────────────────
# 설정 가이드: README.md > KakaoTalk 알림 설정
# access_token은 6시간 만료, 시스템이 자동 갱신
# refresh_token은 2개월 만료, 만료 시 재발급 필요
KAKAO_REST_API_KEY=
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
