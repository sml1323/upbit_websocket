# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=upbit-tickers

# TimescaleDB
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=upbit
DB_USER=postgres
DB_PASSWORD=postgres

# Consumer
BATCH_SIZE=100
BATCH_TIMEOUT_SEC=1.0

# LLM (Agent)
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# News API (optional)
CRYPTOPANIC_API_KEY=
SERPAPI_API_KEY=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO
